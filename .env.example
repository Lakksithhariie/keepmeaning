# Server-side secrets used by the LinkedIn API routes.
TURSO_URL="libsql://your-database.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"
MISTRAL_API_KEY="your-mistral-api-key"

# Backward-compatible aliases still supported by local dev/server code.
VITE_TURSO_URL="libsql://your-database.turso.io"
VITE_TURSO_AUTH_TOKEN="your-turso-auth-token"
VITE_MISTRAL_API_KEY="your-mistral-api-key"

# Existing frontend-only providers used by the Ghostwriter canvas.
VITE_OPENROUTER_API_KEY=""
VITE_INCEPTION_API_KEY=""
VITE_GROQ_API_KEY=""
VITE_GOOGLE_API_KEY=""
VITE_BASEROW_TOKEN=""
